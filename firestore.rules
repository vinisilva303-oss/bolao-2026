rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /boloes/{bolaoId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.ownerId;

      match /participantes/{partId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null && request.auth.uid == partId;
      }

      match /palpites/{partId} {
        allow read: if true;
        allow write: if request.auth == null || request.auth.uid == partId;
      }

      match /resultados/{jogoId} {
        allow read: if true;
        allow write: if request.auth.uid == get(/databases/$(database)/documents/boloes/$(bolaoId)).data.ownerId;
      }
    }

    // Resultados globais — escritos pela Cloud Function (admin SDK ignora regras)
    // Leitura pública; escrita só via backend
    match /resultados_globais/{jogoId} {
      allow read: if true;
      allow write: if false; // apenas Cloud Function via Admin SDK
    }
  }
}
